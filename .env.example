# Logalot local stack — single source of truth for docker compose.
# Copy to `.env` (`make up` / `cp .env.example .env`) and adjust if needed.
# These defaults are for LOCAL DEVELOPMENT ONLY. Never reuse them anywhere real.

# ---------------------------------------------------------------------------
# PostgreSQL — control plane + hot log store (ADR-0003)
# ---------------------------------------------------------------------------
# Two roles, two jobs (see docs/data/migration-plan.md §2 + model.md §4.2):
#   * POSTGRES_USER (admin/migrate) OWNS the schema and runs migrations + seed.
#     The Makefile builds DATABASE_URL from these creds for `make migrate-*`.
#   * logalot_app (provisioned by migration 000011) is the NOSUPERUSER,
#     non-BYPASSRLS login EVERY SERVICE connects as, so FORCE ROW LEVEL SECURITY
#     actually governs it. Services MUST use LOGALOT_APP_DATABASE_URL below — never
#     the admin URL — or the tenant backstop is silently bypassed.
POSTGRES_USER=logalot
POSTGRES_PASSWORD=logalot
POSTGRES_DB=logalot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Admin/migrate connection (DDL, migrations, seed). Host-side it is localhost; the
# dockerized migrate runner rewrites the host to the `postgres` service hostname.
DATABASE_URL=postgres://logalot:logalot@localhost:5432/logalot?sslmode=disable

# Application connection — what ingest/processor/query/control-plane use. Role +
# password are created by migration 000011 (dev creds; rotate for non-local via
# `ALTER ROLE logalot_app PASSWORD '…'`).
LOGALOT_APP_DATABASE_URL=postgres://logalot_app:logalot_app@localhost:5432/logalot?sslmode=disable

# control-plane (auth/tenants/users/keys/RBAC). Connects as logalot_app above.
# JWT_SECRET signs UI session tokens — dev value below; rotate for anything real.
# It is SHARED: control-plane signs with it and query-service VERIFIES UI search/
# tail tokens with the same value (#74). Both require it (min 16 chars); they must
# agree or every browser search/tail request 401s.
# CONTROL_PLANE_PORT is what the web BFF targets (CONTROL_PLANE_URL default :8082).
JWT_SECRET=dev-jwt-secret-change-me-0123456789
CONTROL_PLANE_PORT=8082
# REDIS_URL for the OAuth in-flight state store (issue #89). Single-use CSRF token
# store with ~10-min TTL. Omit locally to fall back to the in-memory store (safe
# for single-process dev only; use Redis in any multi-replica/production setup).
REDIS_URL=redis://:logalot@localhost:6379
# OAUTH_STATE_TTL_SECONDS=600

# alert-evaluator scheduler connection — the BYPASSRLS `logalot_evaluator` role
# (migration 000013). It reads alert-rule scheduling metadata across ALL tenants
# but is granted NOTHING on log_events; log content is read via the logalot_app
# role above under per-tenant RLS (model.md §4.5). Dev creds; rotate for non-local.
LOGALOT_EVALUATOR_DATABASE_URL=postgres://logalot_evaluator:logalot_evaluator@localhost:5432/logalot?sslmode=disable

# alert-evaluator tuning + notifier. Interval must be < 30s (eval-latency NFR).
# ALERT_NOTIFIER=logsink (default, auditable) | sns (floci/AWS SNS fan-out).
ALERT_EVAL_INTERVAL=10s
ALERT_EVAL_BATCH_SIZE=200
ALERT_NOTIFIER=logsink
# ALERT_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:logalot-alerts

# ---------------------------------------------------------------------------
# MongoDB — reserved/unused, present per ADR-0003 alternatives
# ---------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=logalot
MONGO_INITDB_ROOT_PASSWORD=logalot
MONGO_HOST=localhost
MONGO_PORT=27017

# ---------------------------------------------------------------------------
# Redis — tail pub/sub, key cache, rate limit (ADR-0006/0007)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=logalot
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Per-tenant ingest rate limiting (ingest-service, ADR-0004/NFR-3). Redis token
# bucket keyed by the authenticated tenant_id; over-limit => 429 + Retry-After.
# Fails OPEN on a Redis outage by default (admit + warn); set FAIL_OPEN=false to
# reject with 503 instead. Override a single tenant via OVERRIDES:
#   INGEST_RATE_LIMIT_OVERRIDES="<tenant-uuid>=<rps>:<burst>,<tenant-uuid>=0:0"
# (0:0 exempts a tenant).
# ---------------------------------------------------------------------------
# INGEST_RATE_LIMIT_ENABLED=true
# INGEST_RATE_LIMIT_RPS=1000
# INGEST_RATE_LIMIT_BURST=2000
# INGEST_RATE_LIMIT_FAIL_OPEN=true
# INGEST_RATE_LIMIT_OVERRIDES=

# ---------------------------------------------------------------------------
# RabbitMQ — ingest pipeline + DLQ (ADR-0004); management UI on :15672
# ---------------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=logalot
RABBITMQ_DEFAULT_PASS=logalot
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
# RABBITMQ_URL is authoritative when set; otherwise services (ingest #6) assemble
# an amqp URL from the host/port/user/pass above (pkg/broker URLFromEnv).
# RABBITMQ_URL=amqp://logalot:logalot@localhost:5672/

# ---------------------------------------------------------------------------
# floci — AWS-local @ :4566 (S3, Firehose, Athena/Glue, SNS/SQS)
# FLOCI_HOSTNAME lets containers resolve floci-issued URLs as `floci` on the
# user-defined network. FLOCI_STORAGE_MODE=hybrid persists state to a volume.
# ---------------------------------------------------------------------------
FLOCI_VERSION=1.5.28
FLOCI_PORT=4566
FLOCI_HOSTNAME=floci
FLOCI_STORAGE_MODE=hybrid

# AWS SDK config — point every AWS client at floci with dummy creds.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ---------------------------------------------------------------------------
# Vertical slice services (issue #9) — host-published ports for the demo.
# These map host -> container; inter-service traffic uses the compose network
# (service hostnames), so they only matter for reaching the demo from the host.
# ---------------------------------------------------------------------------
# ingest-service POST /v1/ingest
INGEST_PORT=8080
# query-service  GET  /v1/tail (SSE)
QUERY_PORT=8081

# ---------------------------------------------------------------------------
# Burrow-conflict workaround (this host runs a `burrow` stack on the standard
# ports). The slice services reach infra over the compose network regardless, so
# only the HOST-published ports need to move. Uncomment to dodge the clash:
# ---------------------------------------------------------------------------
# REDIS_PORT=6380
# RABBITMQ_PORT=5673
# RABBITMQ_MGMT_PORT=15673
# MONGO_PORT=27018
