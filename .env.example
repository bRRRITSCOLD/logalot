# Logalot local stack — single source of truth for docker compose.
# Copy to `.env` (`make up` / `cp .env.example .env`) and adjust if needed.
# These defaults are for LOCAL DEVELOPMENT ONLY. Never reuse them anywhere real.

# ---------------------------------------------------------------------------
# PostgreSQL — control plane + hot log store (ADR-0003)
# ---------------------------------------------------------------------------
POSTGRES_USER=logalot
POSTGRES_PASSWORD=logalot
POSTGRES_DB=logalot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# MongoDB — reserved/unused, present per ADR-0003 alternatives
# ---------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=logalot
MONGO_INITDB_ROOT_PASSWORD=logalot
MONGO_HOST=localhost
MONGO_PORT=27017

# ---------------------------------------------------------------------------
# Redis — tail pub/sub, key cache, rate limit (ADR-0006/0007)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=logalot
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# RabbitMQ — ingest pipeline + DLQ (ADR-0004); management UI on :15672
# ---------------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=logalot
RABBITMQ_DEFAULT_PASS=logalot
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---------------------------------------------------------------------------
# floci — AWS-local @ :4566 (S3, Firehose, Athena/Glue, SNS/SQS)
# FLOCI_HOSTNAME lets containers resolve floci-issued URLs as `floci` on the
# user-defined network. FLOCI_STORAGE_MODE=hybrid persists state to a volume.
# ---------------------------------------------------------------------------
FLOCI_PORT=4566
FLOCI_HOSTNAME=floci
FLOCI_STORAGE_MODE=hybrid

# AWS SDK config — point every AWS client at floci with dummy creds.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
