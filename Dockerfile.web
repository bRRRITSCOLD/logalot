# Multi-stage Dockerfile for the web TanStack Start BFF + React app.
#
# Build context: REPO ROOT (pnpm workspace resolution requires pnpm-workspace.yaml
# and all workspace packages to be reachable from the build context).
#
#   docker build -f Dockerfile.web -t logalot/web .
#   docker buildx build --platform linux/arm64 -f Dockerfile.web -t logalot/web .
#
# Pipeline:
#   1. `builder`  — install ALL deps (including devDeps needed by Vite/TS), then
#                   run `pnpm --filter @logalot/web build` which:
#                     (a) pre-build: runs build-tokens.mjs to emit src/styles/tokens.css
#                     (b) `vite build`: TanStack Start (Vite plugin, NOT Nitro/Vinxi)
#                         produces two environments:
#                           apps/web/dist/server/server.js   — Node.js ESM fetch handler
#                           apps/web/dist/server/assets/     — server-side split chunks
#                           apps/web/dist/client/assets/     — hashed browser JS/CSS
#   2. `runtime`  — Node 22 Alpine.  Copies the artefacts required to run:
#                     • node_modules/              root pnpm virtual store (.pnpm/)
#                     • apps/web/node_modules/     per-app symlinks → virtual store
#                     • apps/web/dist/             build output (server + client)
#                     • packages/contracts/        resolves @logalot/contracts symlink
#                   node_modules ARE required at runtime: vite build (SSR environment)
#                   externalises `react` and `@tanstack/react-router` — they are NOT
#                   bundled into dist/server/server.js and must be resolvable via
#                   Node.js module-resolution at start-up.
#                   `srvx` (promoted to a direct dep of @logalot/web) provides the
#                   HTTP-server adapter: it imports server.js's default export (a
#                   Web-fetch handler) and serves it over Node.js HTTP.

ARG NODE_VERSION=22

# ---- builder -----------------------------------------------------------------
FROM node:${NODE_VERSION}-alpine AS builder

WORKDIR /build

# Install pnpm via corepack — version pinned to match packageManager in root package.json.
RUN corepack enable && corepack prepare pnpm@10.33.2 --activate

# Workspace manifests — cached layer until any package.json changes.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/contracts/package.json      ./packages/contracts/
COPY packages/design-tokens/package.json  ./packages/design-tokens/
COPY apps/web/package.json                ./apps/web/

# Install all deps (devDeps needed: vite, tailwindcss, tsc, etc.).
RUN pnpm install --frozen-lockfile --filter @logalot/web...

# Copy source AFTER deps to maximise cache reuse on code-only changes.
COPY packages/contracts     ./packages/contracts
COPY packages/design-tokens ./packages/design-tokens
COPY apps/web               ./apps/web

# Build — prebuild hook runs build-tokens.mjs first, then vite build emits:
#   apps/web/dist/server/server.js   Node.js ESM fetch handler
#   apps/web/dist/client/assets/     browser JS/CSS chunks
RUN pnpm --filter @logalot/web build

# ---- runtime -----------------------------------------------------------------
FROM node:${NODE_VERSION}-alpine AS runtime

RUN apk add --no-cache wget \
 && addgroup -S logalot \
 && adduser  -S -G logalot logalot

# WORKDIR mirrors the workspace root so that pnpm symlinks in
# apps/web/node_modules/ (relative: ../../node_modules/.pnpm/…) resolve
# correctly under /app.
WORKDIR /app

# Root pnpm virtual store — every package is here (react, @tanstack/*, srvx…).
# dist/server/server.js imports react and @tanstack/react-router as external
# bare specifiers; Node.js walks up from the file to this directory to find them.
COPY --from=builder /build/node_modules          ./node_modules

# Per-app symlinks that point back into the virtual store above.
# Includes srvx and node_modules/.bin/srvx created by the direct-dep install.
COPY --from=builder /build/apps/web/node_modules ./apps/web/node_modules

# package.json provides "type":"module" so Node.js treats server.js as ESM
# without the parse-twice performance penalty.
COPY --from=builder /build/apps/web/package.json  ./apps/web/package.json

# The production build artefacts (server bundle + browser chunks).
COPY --from=builder /build/apps/web/dist         ./apps/web/dist

# Resolve the @logalot/contracts workspace symlink present in node_modules.
COPY --from=builder /build/packages/contracts    ./packages/contracts

# pnpm workspace resolution reads these at startup.
COPY --from=builder /build/package.json          ./package.json
COPY --from=builder /build/pnpm-workspace.yaml   ./pnpm-workspace.yaml

USER logalot:logalot

EXPOSE 3000

# Liveness probe — the /api/healthz route returns 200 {"status":"ok"} as soon as
# the SSR server is accepting connections (defined in apps/web/src/routes/api/healthz.ts).
HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=3 \
  CMD wget -qO- http://localhost:3000/api/healthz || exit 1

# PORT defaults to 3000; srvx reads process.env.PORT automatically.
# --prod  enables graceful shutdown and sets NODE_ENV=production.
# --dir   tells srvx to root discovery at apps/web/dist; it auto-discovers
#         apps/web/dist/server/server.js via its "server/server" default-entry rule.
# --static serves browser chunks from apps/web/dist/client/ at URL prefix /assets/.
ENV PORT=3000
ENTRYPOINT ["apps/web/node_modules/.bin/srvx", "--prod", "--dir", "apps/web/dist", "--static", "client"]
