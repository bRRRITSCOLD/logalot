        "fontWeight": "{primitive.font.weight.semibold}",
        "lineHeight": "{primitive.font.lineHeight.snug}",
        "letterSpacing": "{primitive.font.letterSpacing.normal}"
      }
    },
    "headingSm": {
      "$value": {
        "fontFamily": "{primitive.font.family.sans}",
        "fontSize": "{primitive.font.size.lg}",
        "fontWeight": "{primitive.font.weight.semibold}",
        "lineHeight": "{primitive.font.lineHeight.snug}",
        "letterSpacing": "{primitive.font.letterSpacing.normal}"
      }
    },
    "body": {
      "$value": {
        "fontFamily": "{primitive.font.family.sans}",
        "fontSize": "{primitive.font.size.base}",
        "fontWeight": "{primitive.font.weight.regular}",
        "lineHeight": "{primitive.font.lineHeight.normal}",
        "letterSpacing": "{primitive.font.letterSpacing.normal}"
      }
    },
    "bodySm": {
      "$value": {
        "fontFamily": "{primitive.font.family.sans}",
        "fontSize": "{primitive.font.size.sm}",
        "fontWeight": "{primitive.font.weight.regular}",
        "lineHeight": "{primitive.font.lineHeight.normal}",
        "letterSpacing": "{primitive.font.letterSpacing.normal}"
      }
    },
    "label": {
      "$value": {
        "fontFamily": "{primitive.font.family.sans}",
        "fontSize": "{primitive.font.size.sm}",
        "fontWeight": "{primitive.font.weight.medium}",
        "lineHeight": "{primitive.font.lineHeight.snug}",
        "letterSpacing": "{primitive.font.letterSpacing.normal}"
      }
    },
    "caption": {
      "$value": {
        "fontFamily": "{primitive.font.family.sans}",
        "fontSize": "{primitive.font.size.xs}",
        "fontWeight": "{primitive.font.weight.regular}",
        "lineHeight": "{primitive.font.lineHeight.snug}",
        "letterSpacing": "{primitive.font.letterSpacing.wide}"
      }
    },
    "button": {
      "$value": {
        "fontFamily": "{primitive.font.family.sans}",
        "fontSize": "{primitive.font.size.base}",
        "fontWeight": "{primitive.font.weight.medium}",
        "lineHeight": "{primitive.font.lineHeight.none}",
        "letterSpacing": "{primitive.font.letterSpacing.normal}"
      }
