{
  "$description": "Logalot design tokens (W3C DTCG). Three layers: `primitive` (raw, theme-agnostic source of truth), `semantic` (intent-named aliases; color/elevation are split into `dark` + `light` theme sets, dark is the default for a log viewer), and composite `typography` tokens. Alpha tints (badge/overlay/hover fills) are literal hex8 values because DTCG aliases cannot apply opacity to a referenced color; every fully-opaque value is an alias to keep one source of truth. Dimensions use the DTCG object form `{value, unit}`.",
  "primitive": {
    "$description": "Raw values. Never consumed directly by components; always referenced via the semantic layer.",
    "color": {
      "$type": "color",
      "neutral": {
        "0": { "$value": "#ffffff" },
        "50": { "$value": "#f8fafc" },
        "100": { "$value": "#f1f5f9" },
        "200": { "$value": "#e2e8f0" },
        "300": { "$value": "#cbd5e1" },
        "400": { "$value": "#94a3b8" },
        "500": { "$value": "#64748b" },
        "600": { "$value": "#475569" },
        "700": { "$value": "#334155" },
        "800": { "$value": "#1e293b" },
        "850": { "$value": "#172033" },
        "900": { "$value": "#0f172a" },
        "925": { "$value": "#0b1220" },
        "950": { "$value": "#020617" },
        "1000": { "$value": "#000000" }
      },
      "brand": {
        "$description": "Indigo. Interactive/primary accent. Deliberately distinct from every severity hue.",
        "50": { "$value": "#eef2ff" },
        "100": { "$value": "#e0e7ff" },
        "200": { "$value": "#c7d2fe" },
        "300": { "$value": "#a5b4fc" },
        "400": { "$value": "#818cf8" },
        "500": { "$value": "#6366f1" },
        "600": { "$value": "#4f46e5" },
        "700": { "$value": "#4338ca" },
        "800": { "$value": "#3730a3" },
        "900": { "$value": "#312e81" },
        "950": { "$value": "#1e1b4b" }
      },
      "cyan": {
        "$description": "Severity: debug.",
        "100": { "$value": "#cffafe" },
        "300": { "$value": "#67e8f9" },
        "400": { "$value": "#22d3ee" },
        "500": { "$value": "#06b6d4" },
        "600": { "$value": "#0891b2" },
        "700": { "$value": "#0e7490" }
      },
      "emerald": {
        "$description": "Severity: info. Also reused for the `success` status role.",
        "100": { "$value": "#d1fae5" },
        "300": { "$value": "#6ee7b7" },
        "400": { "$value": "#34d399" },
        "500": { "$value": "#10b981" },
        "600": { "$value": "#059669" },
        "700": { "$value": "#047857" }
      },
      "amber": {
        "$description": "Severity: warn. Also reused for the `warning` status role.",
        "100": { "$value": "#fef3c7" },
        "300": { "$value": "#fcd34d" },
        "400": { "$value": "#fbbf24" },
        "500": { "$value": "#f59e0b" },
        "600": { "$value": "#d97706" },
        "700": { "$value": "#b45309" }
      },
      "red": {
        "$description": "Severity: error. Also reused for the `danger` status role.",
        "100": { "$value": "#fee2e2" },
        "300": { "$value": "#fca5a5" },
        "400": { "$value": "#f87171" },
        "500": { "$value": "#ef4444" },
        "600": { "$value": "#dc2626" },
        "700": { "$value": "#b91c1c" }
      },
      "violet": {
        "$description": "Severity: fatal. Strongest, beyond error.",
        "100": { "$value": "#ede9fe" },
        "300": { "$value": "#c4b5fd" },
        "400": { "$value": "#a78bfa" },
        "500": { "$value": "#8b5cf6" },
        "600": { "$value": "#7c3aed" },
        "700": { "$value": "#6d28d9" }
      }
    },
    "font": {
      "family": {
        "$type": "fontFamily",
        "mono": {
          "$description": "Log lines, code, timestamps, raw payloads. Tabular, fixed-width.",
          "$value": [
            "JetBrains Mono",
            "Fira Code",
            "ui-monospace",
            "SFMono-Regular",
            "Menlo",
            "Consolas",
            "monospace"
          ]
        },
        "sans": {
          "$description": "UI chrome: nav, labels, buttons, headings.",
          "$value": [
            "Inter",
            "ui-sans-serif",
            "system-ui",
            "-apple-system",
            "Segoe UI",
            "Roboto",
            "Helvetica Neue",
            "Arial",
            "sans-serif"
          ]
        }
      },
      "size": {
        "$type": "dimension",
        "2xs": { "$value": { "value": 11, "unit": "px" } },
        "xs": { "$value": { "value": 12, "unit": "px" } },
        "sm": { "$value": { "value": 13, "unit": "px" } },
        "base": { "$value": { "value": 14, "unit": "px" } },
        "md": { "$value": { "value": 16, "unit": "px" } },
        "lg": { "$value": { "value": 18, "unit": "px" } },
        "xl": { "$value": { "value": 20, "unit": "px" } },
        "2xl": { "$value": { "value": 24, "unit": "px" } },
        "3xl": { "$value": { "value": 30, "unit": "px" } }
      },
      "weight": {
        "$type": "fontWeight",
        "regular": { "$value": 400 },
        "medium": { "$value": 500 },
        "semibold": { "$value": 600 },
        "bold": { "$value": 700 }
      },
      "lineHeight": {
        "$type": "number",
        "none": { "$value": 1 },
        "tight": { "$value": 1.2 },
        "snug": { "$value": 1.35 },
        "log": { "$value": 1.45 },
        "normal": { "$value": 1.5 },
        "relaxed": { "$value": 1.7 }
      },
      "letterSpacing": {
        "$type": "dimension",
        "tight": { "$value": { "value": -0.0125, "unit": "rem" } },
        "normal": { "$value": { "value": 0, "unit": "rem" } },
        "wide": { "$value": { "value": 0.0125, "unit": "rem" } }
      }
    },
    "space": {
      "$type": "dimension",
      "$description": "4px base grid. Numeric keys align with Tailwind spacing (1 = 0.25rem = 4px).",
      "0": { "$value": { "value": 0, "unit": "px" } },
      "px": { "$value": { "value": 1, "unit": "px" } },
      "0.5": { "$value": { "value": 2, "unit": "px" } },
      "1": { "$value": { "value": 4, "unit": "px" } },
      "1.5": { "$value": { "value": 6, "unit": "px" } },
      "2": { "$value": { "value": 8, "unit": "px" } },
      "2.5": { "$value": { "value": 10, "unit": "px" } },
      "3": { "$value": { "value": 12, "unit": "px" } },
      "4": { "$value": { "value": 16, "unit": "px" } },
      "5": { "$value": { "value": 20, "unit": "px" } },
      "6": { "$value": { "value": 24, "unit": "px" } },
      "8": { "$value": { "value": 32, "unit": "px" } },
      "10": { "$value": { "value": 40, "unit": "px" } },
      "12": { "$value": { "value": 48, "unit": "px" } },
      "16": { "$value": { "value": 64, "unit": "px" } },
      "20": { "$value": { "value": 80, "unit": "px" } },
      "24": { "$value": { "value": 96, "unit": "px" } }
    },
    "radius": {
      "$type": "dimension",
      "none": { "$value": { "value": 0, "unit": "px" } },
      "sm": { "$value": { "value": 4, "unit": "px" } },
      "md": { "$value": { "value": 6, "unit": "px" } },
      "lg": { "$value": { "value": 8, "unit": "px" } },
      "xl": { "$value": { "value": 12, "unit": "px" } },
      "2xl": { "$value": { "value": 16, "unit": "px" } },
      "full": { "$value": { "value": 9999, "unit": "px" } }
    },
    "borderWidth": {
      "$type": "dimension",
      "0": { "$value": { "value": 0, "unit": "px" } },
      "thin": { "$value": { "value": 1, "unit": "px" } },
      "thick": { "$value": { "value": 2, "unit": "px" } }
    },
    "zIndex": {
      "$type": "number",
      "base": { "$value": 0 },
      "raised": { "$value": 10 },
      "sticky": { "$value": 1100 },
      "dropdown": { "$value": 1200 },
      "overlay": { "$value": 1300 },
      "modal": { "$value": 1400 },
      "popover": { "$value": 1500 },
      "toast": { "$value": 1600 },
      "tooltip": { "$value": 1700 }
    },
    "duration": {
      "$type": "duration",
      "instant": { "$value": { "value": 0, "unit": "ms" } },
      "fast": { "$value": { "value": 120, "unit": "ms" } },
      "normal": { "$value": { "value": 200, "unit": "ms" } },
      "slow": { "$value": { "value": 320, "unit": "ms" } },
      "slower": { "$value": { "value": 480, "unit": "ms" } }
    },
    "easing": {
      "$type": "cubicBezier",
      "linear": { "$value": [0, 0, 1, 1] },
      "standard": { "$value": [0.2, 0, 0, 1] },
      "in": { "$value": [0.4, 0, 1, 1] },
      "out": { "$value": [0, 0, 0.2, 1] },
      "inOut": { "$value": [0.4, 0, 0.2, 1] }
    },
    "breakpoint": {
      "$type": "dimension",
      "$description": "Tailwind-aligned. Mobile = <md, tablet = md..<lg, desktop = >=lg.",
      "sm": { "$value": { "value": 640, "unit": "px" } },
      "md": { "$value": { "value": 768, "unit": "px" } },
      "lg": { "$value": { "value": 1024, "unit": "px" } },
      "xl": { "$value": { "value": 1280, "unit": "px" } },
      "2xl": { "$value": { "value": 1536, "unit": "px" } }
    }
  },
  "semantic": {
    "$description": "Intent-named aliases consumed by components. Color + elevation are themed (dark default, light override); everything else is theme-agnostic.",
    "color": {
      "$type": "color",
      "dark": {
        "$description": "Default theme for the log viewer.",
        "bg": {
          "base": { "$value": "{primitive.color.neutral.950}" },
          "surface": { "$value": "{primitive.color.neutral.900}" },
          "elevated": { "$value": "{primitive.color.neutral.850}" },
          "inset": { "$value": "{primitive.color.neutral.925}" },
          "overlay": { "$value": "#00000099" },
          "hover": { "$value": "#ffffff0a" },
          "active": { "$value": "#ffffff14" },
          "selected": { "$value": "#6366f124" }
        },
        "fg": {
          "default": { "$value": "{primitive.color.neutral.100}" },
          "muted": { "$value": "{primitive.color.neutral.400}" },
          "subtle": { "$value": "{primitive.color.neutral.500}" },
          "inverse": { "$value": "{primitive.color.neutral.950}" },
          "onBrand": { "$value": "{primitive.color.neutral.0}" },
          "link": { "$value": "{primitive.color.brand.400}" }
        },
        "border": {
          "default": { "$value": "{primitive.color.neutral.800}" },
          "subtle": { "$value": "#ffffff14" },
          "strong": { "$value": "{primitive.color.neutral.700}" },
          "focus": { "$value": "{primitive.color.brand.400}" }
        },
        "brand": {
          "solid": { "$value": "{primitive.color.brand.600}" },
          "solidHover": { "$value": "{primitive.color.brand.500}" },
          "solidActive": { "$value": "{primitive.color.brand.700}" },
          "fg": { "$value": "{primitive.color.brand.400}" },
          "muted": { "$value": "#6366f124" }
        },
        "status": {
          "success": { "$value": "{primitive.color.emerald.400}" },
          "warning": { "$value": "{primitive.color.amber.400}" },
          "danger": { "$value": "{primitive.color.red.400}" },
          "info": { "$value": "{primitive.color.cyan.400}" }
        },
        "severity": {
          "$description": "Per log level: fg (text/icon, bright on dark), bg (subtle badge fill ~14% alpha), border (~30% alpha).",
          "trace": {
            "fg": { "$value": "{primitive.color.neutral.400}" },
            "bg": { "$value": "#64748b24" },
            "border": { "$value": "#64748b4d" }
          },
          "debug": {
            "fg": { "$value": "{primitive.color.cyan.300}" },
            "bg": { "$value": "#06b6d424" },
            "border": { "$value": "#06b6d44d" }
          },
          "info": {
            "fg": { "$value": "{primitive.color.emerald.300}" },
            "bg": { "$value": "#10b98124" },
            "border": { "$value": "#10b9814d" }
          },
          "warn": {
            "fg": { "$value": "{primitive.color.amber.300}" },
            "bg": { "$value": "#f59e0b24" },
            "border": { "$value": "#f59e0b4d" }
          },
          "error": {
            "fg": { "$value": "{primitive.color.red.400}" },
            "bg": { "$value": "#ef444424" },
            "border": { "$value": "#ef44444d" }
          },
          "fatal": {
            "fg": { "$value": "{primitive.color.violet.300}" },
            "bg": { "$value": "#8b5cf62e" },
            "border": { "$value": "#8b5cf65c" }
          }
        }
      },
      "light": {
        "$description": "Light theme override of the semantic color set.",
        "bg": {
          "base": { "$value": "{primitive.color.neutral.50}" },
          "surface": { "$value": "{primitive.color.neutral.0}" },
          "elevated": { "$value": "{primitive.color.neutral.0}" },
          "inset": { "$value": "{primitive.color.neutral.100}" },
          "overlay": { "$value": "#0f172a66" },
          "hover": { "$value": "#0f172a0a" },
          "active": { "$value": "#0f172a14" },
          "selected": { "$value": "#6366f11f" }
        },
        "fg": {
          "default": { "$value": "{primitive.color.neutral.900}" },
          "muted": { "$value": "{primitive.color.neutral.500}" },
          "subtle": { "$value": "{primitive.color.neutral.400}" },
          "inverse": { "$value": "{primitive.color.neutral.0}" },
          "onBrand": { "$value": "{primitive.color.neutral.0}" },
          "link": { "$value": "{primitive.color.brand.600}" }
        },
        "border": {
          "default": { "$value": "{primitive.color.neutral.200}" },
          "subtle": { "$value": "#0f172a0f" },
          "strong": { "$value": "{primitive.color.neutral.300}" },
          "focus": { "$value": "{primitive.color.brand.500}" }
        },
        "brand": {
          "solid": { "$value": "{primitive.color.brand.600}" },
          "solidHover": { "$value": "{primitive.color.brand.700}" },
          "solidActive": { "$value": "{primitive.color.brand.800}" },
          "fg": { "$value": "{primitive.color.brand.600}" },
          "muted": { "$value": "#6366f11f" }
        },
        "status": {
          "success": { "$value": "{primitive.color.emerald.600}" },
          "warning": { "$value": "{primitive.color.amber.600}" },
          "danger": { "$value": "{primitive.color.red.600}" },
          "info": { "$value": "{primitive.color.cyan.600}" }
        },
        "severity": {
          "$description": "Per log level on light surfaces: fg (700, readable on light), bg (~12% alpha), border (~25% alpha).",
          "trace": {
            "fg": { "$value": "{primitive.color.neutral.600}" },
            "bg": { "$value": "#64748b1f" },
            "border": { "$value": "#64748b40" }
          },
          "debug": {
            "fg": { "$value": "{primitive.color.cyan.700}" },
            "bg": { "$value": "#06b6d41f" },
            "border": { "$value": "#06b6d440" }
          },
          "info": {
            "fg": { "$value": "{primitive.color.emerald.700}" },
            "bg": { "$value": "#10b9811f" },
            "border": { "$value": "#10b98140" }
          },
          "warn": {
            "fg": { "$value": "{primitive.color.amber.700}" },
            "bg": { "$value": "#f59e0b1f" },
            "border": { "$value": "#f59e0b40" }
          },
          "error": {
            "fg": { "$value": "{primitive.color.red.700}" },
            "bg": { "$value": "#ef44441f" },
            "border": { "$value": "#ef444440" }
          },
          "fatal": {
            "fg": { "$value": "{primitive.color.violet.700}" },
            "bg": { "$value": "#8b5cf61f" },
            "border": { "$value": "#8b5cf640" }
          }
        }
      }
    },
    "elevation": {
      "$type": "shadow",
      "dark": {
        "$description": "Darker, higher-contrast shadows for the dark theme.",
        "sm": {
          "$value": {
            "color": "#00000066",
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 1, "unit": "px" },
            "blur": { "value": 2, "unit": "px" },
            "spread": { "value": 0, "unit": "px" }
          }
        },
        "md": {
          "$value": {
            "color": "#0000008c",
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 4, "unit": "px" },
            "blur": { "value": 8, "unit": "px" },
            "spread": { "value": -2, "unit": "px" }
          }
        },
        "lg": {
          "$value": {
            "color": "#000000a6",
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 12, "unit": "px" },
            "blur": { "value": 24, "unit": "px" },
            "spread": { "value": -6, "unit": "px" }
          }
        },
        "xl": {
          "$value": {
            "color": "#000000bf",
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 24, "unit": "px" },
            "blur": { "value": 48, "unit": "px" },
            "spread": { "value": -12, "unit": "px" }
          }
        }
      },
      "light": {
        "$description": "Softer shadows for the light theme.",
        "sm": {
          "$value": {
            "color": "#0f172a14",
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 1, "unit": "px" },
            "blur": { "value": 2, "unit": "px" },
            "spread": { "value": 0, "unit": "px" }
          }
        },
        "md": {
          "$value": {
            "color": "#0f172a1f",
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 4, "unit": "px" },
            "blur": { "value": 8, "unit": "px" },
            "spread": { "value": -2, "unit": "px" }
          }
        },
        "lg": {
          "$value": {
            "color": "#0f172a29",
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 12, "unit": "px" },
            "blur": { "value": 24, "unit": "px" },
            "spread": { "value": -6, "unit": "px" }
          }
        },
        "xl": {
          "$value": {
            "color": "#0f172a33",
            "offsetX": { "value": 0, "unit": "px" },
            "offsetY": { "value": 24, "unit": "px" },
            "blur": { "value": 48, "unit": "px" },
            "spread": { "value": -12, "unit": "px" }
          }
        }
      }
    },
    "radius": {
      "$type": "dimension",
      "control": { "$value": "{primitive.radius.md}" },
      "input": { "$value": "{primitive.radius.md}" },
      "card": { "$value": "{primitive.radius.lg}" },
      "panel": { "$value": "{primitive.radius.xl}" },
      "pill": { "$value": "{primitive.radius.full}" }
    },
    "size": {
      "$type": "dimension",
      "$description": "Interactive control heights and icon sizes for cva size variants.",
      "control": {
        "sm": { "$value": { "value": 28, "unit": "px" } },
        "md": { "$value": { "value": 32, "unit": "px" } },
        "lg": { "$value": { "value": 40, "unit": "px" } }
      },
      "icon": {
        "sm": { "$value": { "value": 14, "unit": "px" } },
        "md": { "$value": { "value": 16, "unit": "px" } },
        "lg": { "$value": { "value": 20, "unit": "px" } }
      }
    }
  },
  "typography": {
    "$type": "typography",
    "$description": "Composite type styles. Each references primitive font tokens. `code`/`logLine`/`logMeta` use the mono family; all others use sans.",
    "display": {
      "$value": {
        "fontFamily": "{primitive.font.family.sans}",
        "fontSize": "{primitive.font.size.3xl}",
        "fontWeight": "{primitive.font.weight.bold}",
        "lineHeight": "{primitive.font.lineHeight.tight}",
        "letterSpacing": "{primitive.font.letterSpacing.tight}"
      }
    },
    "headingLg": {
      "$value": {
        "fontFamily": "{primitive.font.family.sans}",
        "fontSize": "{primitive.font.size.2xl}",
        "fontWeight": "{primitive.font.weight.semibold}",
        "lineHeight": "{primitive.font.lineHeight.tight}",
        "letterSpacing": "{primitive.font.letterSpacing.tight}"
      }
    },
    "headingMd": {
      "$value": {
        "fontFamily": "{primitive.font.family.sans}",
