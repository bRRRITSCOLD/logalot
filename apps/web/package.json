{
  "name": "@logalot/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Logalot admin UI: TanStack Start app + BFF. Holds the session, proxies to control-plane/query with the session JWT.",
  "scripts": {
    "predev": "node scripts/build-tokens.mjs",
    "dev": "vite dev --port 3000",
    "prebuild": "node scripts/build-tokens.mjs",
    "build": "vite build",
    "serve": "vite preview --port 3000",
    "tokens": "node scripts/build-tokens.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@logalot/contracts": "workspace:*",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "nuqs": "^2.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@logalot/design-tokens": "workspace:*",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.6.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
