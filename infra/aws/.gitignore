# Terraform local state (bootstrap uses local state; never commit it)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Backend config contains account-specific bucket names — not committed
backend.hcl
*.auto.backend.hcl

# Per-env var files with real values — not committed
*.tfvars
!*.tfvars.example

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log
