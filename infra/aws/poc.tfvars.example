# Copy to poc.tfvars (not committed) and fill in real values.
aws_region   = "us-east-1"
project      = "logalot"
env          = "poc"
state_bucket = "logalot-poc-tf-state-<account_id>"

# ── S3 / cold tier ───────────────────────────────────────────────────────────
cold_retention_days = 90

# ── DNS / TLS ─────────────────────────────────────────────────────────────────
# Must match the domain registered with your DNS registrar.
# Google OAuth redirect URI and Caddy ACME cert use this domain (ADR-0010).
domain_name = "logalot.example.com"

# ── EC2 wiring (populated after ec2.tf is applied) ───────────────────────────
# eip_public_ip   = "<EIP public IP>"   # aws_eip.instance.public_ip
# ec2_instance_id = "<instance-id>"     # aws_instance.main.id

# ── Alerts ───────────────────────────────────────────────────────────────────
alert_email = "ops@example.com"
# Network (defaults match ADR-0009 topology; override only if CIDRs conflict)
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"
availability_zone  = "us-east-1a"

# Admin access — leave empty to keep port 22 closed (use SSM Session Manager).
# Set to your IP/32 only as a fallback when SSM is unavailable.
# admin_cidr = "203.0.113.10/32"
admin_cidr = ""
