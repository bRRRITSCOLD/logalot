{
  "name": "@logalot/control-plane",
  "version": "0.0.0",
  "private": true,
  "description": "Control-plane service (Node + Fastify): tenants/users/api-keys CRUD, RBAC, JWT sessions.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && biome check src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.1.0",
    "@logalot/contracts": "workspace:*",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.2.1",
    "ioredis": "^5.11.1",
    "jose": "^5.9.6",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@testcontainers/redis": "^12.0.3",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  }
}
